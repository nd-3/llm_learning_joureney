# --- Secrets ---
# APIキーやパスワードを記載する.envファイルを無視する
.env
.env.*
# ただしテンプレート(ダミー値のみ)は例外としてコミット対象にする
!.env.example

# --- Python ---
# 仮想環境フォルダ
.venv/
venv/
env/

# Pythonキャッシュファイル
__pycache__/
*.pyc

# ChromaDBの永続化データ(生成物のためコミット不要)。
# ディレクトリ名に埋め込みモデル名が付く(例: chroma_db_text-embedding-3-small)ため
# ワイルドカードで指定する。
03_portfolio/techdoc-qa-bot/data/chroma_db*/

# 評価用ベクトルDB(設定ごとに評価実行時に生成される)
03_portfolio/techdoc-qa-bot/evals/db/

# 評価用に外部から取得した公開PDF(再配布を避けるためコミットしない。入手元はREADME参照)
03_portfolio/techdoc-qa-bot/data/kyodai_python_2023.pdf

# skill-match-analyzer: 実データのスキルプロファイル(個人情報のためコミット不要)。
# テンプレートは skill_profile.example.yaml としてコミット対象にする。
03_portfolio/skill-match-analyzer/skill_profile.yaml

# --- IDE/Editor Settings ---
# VSCodeの設定フォルダ
.vscode/

